{
  // wrangler.jsonc for deploy sveltekit to cloudflare
  "name": "think",
  "compatibility_flags": ["nodejs_compat"],
  "compatibility_date": "2024-10-22",
  "pages_build_output_dir": ".svelte-kit/cloudflare",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "think",
      "database_id": "aa8eef38-44b8-46e3-804c-d683fc5e177d"
    }
  ]
} 