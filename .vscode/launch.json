{
    "version": "0.2.0",
    "configurations": [    
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Wrangler",
            "runtimeExecutable": "npx",
            "runtimeArgs": ["wrangler", "dev", "--live-reload", "--local"],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "restart": true,
            "autoAttachChildProcesses": true
        }
    ]
} 